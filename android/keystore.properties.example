# Copy this file to android/keystore.properties and fill it locally.
# Never commit android/keystore.properties or the keystore file.

DASHAI_UPLOAD_STORE_FILE=C:\\Users\\msi\\DashAI\\keys\\dashai-upload.jks
DASHAI_UPLOAD_STORE_PASSWORD=replace-with-a-long-private-password
DASHAI_UPLOAD_KEY_ALIAS=dashai-upload
DASHAI_UPLOAD_KEY_PASSWORD=replace-with-a-long-private-password

# Required before publishing a release build to Google Play.
# This must be a public HTTPS backend, never a local http:// address.
DASHAI_PROD_API_ENDPOINT=https://api.your-domain.example/api/ask

# Optional local debug endpoint.
DASHAI_DEBUG_API_ENDPOINT=http://172.20.10.4:8000/api/ask
