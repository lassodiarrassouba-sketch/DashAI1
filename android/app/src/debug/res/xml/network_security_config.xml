<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        APK debug uniquement.
        Permet de tester un backend local en HTTP, par exemple :
        http://10.0.2.2:8000/api/ask depuis l'émulateur
        http://192.168.x.x:8000/api/ask ou http://172.20.x.x:8000/api/ask depuis un vrai téléphone

        Pour une version publiée, utilisez HTTPS et gardez la configuration stricte de src/main.
    -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
