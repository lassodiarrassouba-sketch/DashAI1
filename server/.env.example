# Ne jamais mettre cette clé dans l'application Android.
OPENAI_API_KEY=sk-proj-votre-cle-ici

# Modèle par défaut, modifiable selon votre budget et votre latence cible.
OPENAI_MODEL=gpt-5.4-mini
MAX_OUTPUT_TOKENS=700

# Fournisseur gratuit prioritaire. En mode auto, DIASCO utilise Cloudflare s'il est
# configuré, puis OpenAI comme secours. Garder ces secrets uniquement côté serveur.
AI_PROVIDER=auto
IMAGE_PROVIDER=auto
VISION_PROVIDER=auto
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TEXT_MODEL=@cf/meta/llama-3.1-8b-instruct-fp8-fast
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
CLOUDFLARE_IMAGE_STEPS=4
CLOUDFLARE_VISION_MODEL=@cf/meta/llama-3.2-11b-vision-instruct

# Domaines web autorisés à appeler le backend depuis un navigateur.
# Exemple production Netlify :
# ALLOWED_ORIGINS=https://dashai-votre-nom.netlify.app
ALLOWED_ORIGINS=http://localhost:8888,http://127.0.0.1:8888
